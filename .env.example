# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database / Prisma
DATABASE_URL=
DIRECT_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (requerido para IA y Smart Import)
OPENAI_API_KEY=

# Upstash Redis (requerido para rate limiting en producción)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (opcional — error tracking en producción)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags operativos
DISABLE_AI=                     # Deshabilita todos los endpoints de IA (1 = deshabilitado)
DISABLE_SMART_IMPORT=           # Deshabilita Smart Import sin deshabilitar IA (1 = deshabilitado)
BETA_ALLOWLIST_EMAILS=          # Lista de emails separados por coma (vacío = acceso libre)
MAINTENANCE_MODE=               # Devuelve 503 en todas las rutas (1 = activo)
ENABLE_PWA=                     # Habilita PWA (deshabilitada por defecto en beta) (1 = activo)
